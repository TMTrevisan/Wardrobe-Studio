# Supabase Configuration
# Replace these with your actual Supabase URL and Anon API key
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Server-only admin key used only by legacy system jobs. Never prefix with NEXT_PUBLIC.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Gemini API Configuration
# Replace with your Gemini API key from Google AI Studio
GEMINI_API_KEY=your-gemini-api-key-here

# GPT Image 2 powers catalog reconstruction and personalized outfit renders.
OPENAI_API_KEY=your-openai-key-here

# Google Photos Picker (web/mobile). Create an OAuth 2.0 Web Client in
# Google Cloud and allow your local + deployed origins.
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com

# Optional model overrides.
GEMINI_VISION_MODEL=gemini-3.1-flash-lite
OPENAI_IMAGE_MODEL=gpt-image-2

# ── Image Search Engines ─────────────────────────────────────────────────────
# The app tries these in priority order until one succeeds.

# OPTION 1: Bing Image Search (recommended – 1,000 free queries/month)
# Setup: https://portal.azure.com → "Create a resource" → search "Bing Search v7"
#        → Create → Copy "Key 1" from Keys & Endpoint
BING_SEARCH_KEY=your-bing-api-key-here

# OPTION 2: Serper.dev – Google Image Search proxy (2,500 free queries total)
# Setup: https://serper.dev → sign up → Dashboard → copy API key
SERPER_API_KEY=your-serper-api-key-here

# OPTION 3: Google Programmable Search Engine (legacy – only works for engines
#           created BEFORE Jan 20, 2026 that still have "Search the entire web" ON)
GOOGLE_CSE_KEY=your-google-api-key-here
GOOGLE_CSE_CX=your-search-engine-id-here

# Chat Provider API Keys (optional – override the default Gemini key above)
ANTHROPIC_API_KEY=your-anthropic-key-here
DEEPSEEK_API_KEY=your-deepseek-key-here
MINIMAX_API_KEY=your-minimax-key-here
